# Gabagool Bot - Environment Variables
# Version: 1.0
# Created: 2026-01-26
#
# IMPORTANT: Copy this file to .env and fill in your values
# NEVER commit .env to version control!
#
# cp .env.example .env
# nano .env

# =============================================================================
# WALLET CONFIGURATION (REQUIRED)
# =============================================================================

# Your Polygon wallet private key (without 0x prefix)
# Generate a NEW wallet dedicated to this bot - do not use your main wallet!
POLY_PRIVATE_KEY=your_private_key_here_without_0x

# Your Polymarket safe address (proxy wallet address)
# Get this from your Polymarket account settings
POLY_SAFE_ADDRESS=0xYourPolymarketSafeAddress

# =============================================================================
# POLYMARKET API (OPTIONAL - for gasless trades)
# =============================================================================

# Builder program credentials (optional - enables gasless transactions)
# Apply at: https://docs.polymarket.com/
POLY_BUILDER_API_KEY=
POLY_BUILDER_API_SECRET=
POLY_BUILDER_API_PASSPHRASE=

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Polygon RPC endpoint (use a reliable provider)
# Free: https://polygon-rpc.com
# Recommended: Alchemy, Infura, or QuickNode
POLYGON_RPC_URL=https://polygon-rpc.com

# Chain ID (137 for Polygon mainnet)
CHAIN_ID=137

# =============================================================================
# POLYMARKET ENDPOINTS
# =============================================================================

# CLOB API endpoint
CLOB_API_URL=https://clob.polymarket.com

# Gamma API endpoint (for market discovery)
GAMMA_API_URL=https://gamma-api.polymarket.com

# =============================================================================
# RUNTIME MODE
# =============================================================================

# Set to 'production' for live trading, 'development' for testing
ENVIRONMENT=development

# Enable dry-run mode (simulates trades without execution)
DRY_RUN=true

# =============================================================================
# OVERRIDE PARAMETERS (OPTIONAL)
# =============================================================================

# Override config file parameters via environment
# Uncomment and modify as needed

# YES_THRESHOLD=0.48
# NO_THRESHOLD=0.48
# MAX_COMBINED_COST=0.97
# MIN_PROFIT_MARGIN=0.02
# TRADE_SIZE=5.0

# MAX_POSITION_PER_MARKET=100.0
# MAX_TOTAL_EXPOSURE=500.0
# MAX_CONCURRENT_ARBITRAGES=3

# =============================================================================
# ALERTS (OPTIONAL)
# =============================================================================

# Telegram alerts (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Discord webhook (optional)
# DISCORD_WEBHOOK_URL=
