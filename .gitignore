# IDE
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# =============================================================================
# Data and Secrets (NEVER COMMIT)
# =============================================================================
*.db
*.sqlite
*.sqlite3
data/
logs/
*.log

# API credentials
*_creds.json
api_creds.json
credentials.json

# Environment files with secrets
.env
!config/.env.example

# Private keys (CRITICAL - never commit)
*.pem
*.key
private_key*

